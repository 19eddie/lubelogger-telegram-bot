# Telegram Bot Configuration
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# LubeLogger API Configuration
# Base URL of your LubeLogger instance
LUBELOGGER_URL=http://lubelogger:8080
# API key configured in LubeLogger settings
LUBELOGGER_API_KEY=your-lubelogger-api-key

# Access Control
# Comma-separated list of Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321

# Database (optional, defaults to /data/bot.db)
DB_PATH=/data/bot.db

# Queue retry interval in seconds (optional, defaults to 300 = 5 minutes)
QUEUE_RETRY_INTERVAL=300

# HTTP timeout in seconds for LubeLogger API calls (optional, defaults to 10)
HTTP_TIMEOUT=10

# Max retry attempts for queued records (optional, defaults to 3)
MAX_RETRY_ATTEMPTS=3
